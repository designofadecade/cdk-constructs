{
  "name": "@designofadecade/cdk-constructs",
  "version": "1.18.0",
  "description": "TypeScript AWS CDK constructs library providing high-level abstractions for VPC, RDS, S3, CloudFront, Cognito authentication, Lambda functions, API Gateway, DynamoDB, SES, SQS, and more",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && npm run copy-assets",
    "copy-assets": "cp src/assets/functions/cognito/custom-message/*.html dist/assets/functions/cognito/custom-message/ && find src/assets/functions/monitoring -name 'package.json' -exec sh -c 'cp \"$1\" \"dist/assets/functions/monitoring/$(basename $(dirname \"$1\"))/\"' _ {} \\;",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aws",
    "cdk",
    "constructs",
    "infrastructure",
    "deployment"
  ],
  "author": "Design of a Decade <info@designofadecade.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/designofadecade/cdk-constructs.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.240.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-sns": "^3.1003.0",
    "@aws-sdk/client-ssm": "^3.1003.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "aws-cdk-lib": "^2.240.0",
    "aws-sdk-client-mock": "^4.1.0",
    "constructs": "^10.3.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.996.0",
    "@aws-sdk/cloudfront-signer": "^3.993.0",
    "aws-jwt-verify": "^5.1.1"
  }
}
